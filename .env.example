# Local dev — copy to .env and fill in as needed.
# Nothing here is a real secret in v0; when we wire real LLM calls, put the
# provider keys in .env (which is gitignored).

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://platform:platform@127.0.0.1:5433/platform

# ── Dev tenant (hardcoded — replace with WorkOS auth later) ────────────
DEV_ORG_ID=00000000-0000-0000-0000-000000000000
DEV_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
DEV_USER_ID=user_dev

# ── API service ────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=3000

# ── Worker ─────────────────────────────────────────────────────────────
WORKER_POLL_MS=1000
WORKER_CONCURRENCY=1
ARTIFACTS_DIR=./local-artifacts

# ── LLM providers (unused until W3 — activities are stubs today) ───────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Playwright (existing seed test) ────────────────────────────────────
# PLAYWRIGHT_BASE_URL=
# PLAYWRIGHT_WEB_SERVER_COMMAND=
# PLAYWRIGHT_WEB_SERVER_URL=

# ── Legacy agent-server (still in packages/agent-server for now) ───────
# LEGACY_AGENT_PORT=3847
