# Local dev — copy to .env and fill in as needed.
# .env is gitignored; never commit real secrets.

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://platform:platform@127.0.0.1:5433/platform

# ── Dev tenant (hardcoded — replace with real auth when we deploy) ─────
DEV_ORG_ID=00000000-0000-0000-0000-000000000000
DEV_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
DEV_USER_ID=user_dev

# ── API service ────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=3001

# ── Worker ─────────────────────────────────────────────────────────────
WORKER_POLL_MS=1000
WORKER_CONCURRENCY=1
ARTIFACTS_DIR=./local-artifacts

# ── LLM providers (at least one required) ──────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional — pick a specific model. Defaults resolve based on which key is set.
# LLM_MODEL=openai/gpt-4o-mini

# ── Browser + Playwright ───────────────────────────────────────────────
# BROWSER_HEADED=false
# BROWSER_TIMEOUT_MS=180000
# TEST_TIMEOUT_MS=120000

# Playwright project name to pass as --project. Leave unset to let
# Playwright pick the default (right for repos with named projects like
# "auth-setup", "chromium", "iac-chromium", or when using dependencies).
# PLAYWRIGHT_PROJECT=chromium

# ── Structured logs ────────────────────────────────────────────────────
# LOG_PRETTY=true       # for interactive dev (falls back to JSON in CI)
# LOG_LEVEL=info
