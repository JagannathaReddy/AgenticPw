# OpenAI (default Stagehand model client)
OPENAI_API_KEY=

# Or use Anthropic / Google instead of OpenAI
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Agent daemon
AGENT_PORT=3847
AGENT_HOST=127.0.0.1
# Optional fallback when jobs omit an explicit URL (leave empty to require URL per job)
AGENT_DEFAULT_URL=
AGENT_MAX_STEPS=30
AGENT_MAX_STEPS_CAP=100
AGENT_JOB_TIMEOUT_MS=300000
# Hostnames only (or full URLs — hostname is extracted). Example: example.com,https://app.example.com
AGENT_ALLOWED_HOSTS=127.0.0.1,localhost
AGENT_MODEL=openai/gpt-4o-mini
AGENT_RATE_LIMIT_PER_MIN=30
AGENT_REQUIRE_API_KEY=true
AGENT_AUTO_BRIDGE=false
AGENT_LOOP_LEVEL=4
AGENT_MAX_HEAL_ATTEMPTS=3
AGENT_TEST_TIMEOUT_MS=180000
AGENT_TEST_HEADED=false
AGENT_HEAL_A11Y=true

# Optional live job smoke (scripts/agent-smoke.sh)
# AGENT_SMOKE_GOAL=
# AGENT_SMOKE_URL=

# Playwright (optional local app under test)
# PLAYWRIGHT_BASE_URL=
# PLAYWRIGHT_WEB_SERVER_COMMAND=
# PLAYWRIGHT_WEB_SERVER_URL=

# Stagehand runtime
STAGEHAND_ENV=LOCAL
# BROWSERBASE_API_KEY=   # required when STAGEHAND_ENV=BROWSERBASE
