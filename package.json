{
  "name": "test-agent-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic QA platform — Coverage MVP running locally",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker -c cyan,magenta \"npm:dev -w @poc/api\" \"npm:dev -w @poc/worker\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b packages/ops-types packages/ops-prompts apps/api apps/worker",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres && bash scripts/wait-for-postgres.sh && bash scripts/dev-migrate.sh",
    "db:migrate": "bash scripts/dev-migrate.sh",
    "db:seed": "tsx scripts/seed-dev-tenant.ts",
    "dev:up": "bash scripts/dev-up.sh",
    "test:rls": "npm run test -w @poc/rls-tests",
    "test:playwright": "playwright test",
    "eval": "npm run eval -w @poc/eval-harness",
    "prompts:validate": "tsx -e \"import('@poc/prompts').then(m => m.validateAllPrompts().then(ms => console.log('✓', ms.length, 'prompts valid')))\"",
    "loop": "bash scripts/loop.sh",
    "loop:verify": "playwright test && node scripts/record-loop-state.js pass",
    "loop:state": "bash scripts/loop-state.sh show"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
