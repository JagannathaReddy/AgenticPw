{
  "name": "test-agent-platform",
  "version": "0.9.0",
  "private": true,
  "description": "Agentic QA platform — Coverage + Onboarding + Triage + Improve + Steward running locally",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker -c cyan,magenta \"npm:dev -w @poc/api\" \"npm:dev -w @poc/worker\"",
    "agent": "tsx --env-file-if-exists=.env scripts/test-agent.ts",
    "build": "npm run build -w @poc/types && npm run build -w @poc/prompts && npm run build -w @poc/eval-harness && npm run build -w @poc/rls-tests && npm run build -w @poc/api && npm run build -w @poc/worker",
    "typecheck": "tsc -b packages/ops-types packages/ops-prompts apps/api apps/worker",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres && bash scripts/db-wait-for-postgres.sh && bash scripts/db-migrate.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:seed": "tsx --env-file-if-exists=.env scripts/db-seed-dev-tenant.ts",
    "dev:up": "bash scripts/dev-up.sh",
    "demo:reset": "bash scripts/demo-reset.sh",
    "test:rls": "npm run test -w @poc/rls-tests",
    "test:playwright": "playwright test",
    "eval": "npm run eval -w @poc/eval-harness",
    "prompts:validate": "tsx -e \"import('@poc/prompts').then(m => m.validateAllPrompts().then(ms => console.log('✓', ms.length, 'prompts valid')))\""
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
