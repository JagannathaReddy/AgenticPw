{
  "name": "playwright-specialist-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright Specialist Agent platform with Loop Engineering",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:list": "playwright test --list",
    "report": "playwright show-report",
    "loop": "bash scripts/loop.sh",
    "loop:verify": "playwright test && node scripts/record-loop-state.js pass",
    "loop:state": "bash scripts/loop-state.sh show",
    "agent:build": "npm run build --workspace=@poc/agent-server",
    "agent:dev": "tsx packages/agent-server/src/index.ts",
    "agent:start": "node packages/agent-server/dist/index.js",
    "agent:submit": "bash scripts/agent-cli.sh submit"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
